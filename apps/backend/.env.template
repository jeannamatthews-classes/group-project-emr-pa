# Use 5001+ on macOS: port 5000 is often taken by AirPlay Receiver (breaks CORS / returns 403)
PORT=5001
# Comma-separated if the Vite dev server uses a different port (e.g. 5174)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emrpa?schema=public"
JWT_SECRET=replace_with_a_secure_secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="no-reply@example.com"
