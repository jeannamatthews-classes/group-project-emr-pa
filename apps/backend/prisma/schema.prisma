generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// App login accounts (JWT auth).
model User {
  id         String   @id @default(uuid())
  username   String   @unique
  firstName  String?
  lastName   String?
  email      String   @unique
  password   String
  role       String   @default("unassigned")
  emailVerifiedAt             DateTime?
  emailVerificationBypassedAt DateTime?
  verificationCodeHash        String?
  verificationCodeExpiresAt   DateTime?
  verificationAttempts        Int      @default(0)
  verificationResendAvailableAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  actedLogs  AuditLog[] @relation("AuditActor")
  targetLogs AuditLog[] @relation("AuditTarget")
  notes      Note[]

  patientsCreatedAsFaculty Patient[]        @relation("PatientsCreatedByFaculty")
  caseAssignmentsAsStudent CaseAssignment[] @relation("CaseAssignmentStudent")
  caseAssignmentsAsFaculty CaseAssignment[] @relation("CaseAssignmentFaculty")
  caseLabsUploaded         CaseLab[]        @relation("CaseLabsUploadedByFaculty")
  courseMemberships        CourseMember[]
  coursesCreated           Course[]         @relation("CoursesCreatedByFaculty")
}

/// Faculty-created course cohort. Cases, enrolled students, and faculty reviewers are scoped here.
model Course {
  id                 String   @id @default(cuid())
  name               String
  code               String?
  description        String?
  createdByFacultyId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdByFaculty User?          @relation("CoursesCreatedByFaculty", fields: [createdByFacultyId], references: [id], onDelete: SetNull)
  members          CourseMember[]
  patients         Patient[]

  @@index([createdByFacultyId])
  @@index([name])
}

/// Course roster. Only student members see assigned cases in the course, and only faculty members review them.
model CourseMember {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  role      String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId, role])
  @@index([userId, role])
}

/// Patient / chart header (demographics + status).
model Patient {
  id                Int      @id @default(autoincrement())
  /// Optional case title shown in the student UI.
  caseTitle         String?
  /// Patient full name.
  name              String
  location          String
  dob               DateTime @db.Date
  gender            String
  codeStatus        String
  /// "pbl" or "sim" — set by faculty when creating the case.
  caseType          String   @default("pbl")
  /// True when the faculty has attached lab data to this case.
  hasLabs           Boolean  @default(false)
  /// URL of the patient profile picture (served from /uploads).
  profilePictureUrl String?
  /// Faculty user who created this case.
  facultyCreatorId  String?
  /// Course that owns this case.
  courseId          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  facultyCreator  User?            @relation("PatientsCreatedByFaculty", fields: [facultyCreatorId], references: [id], onDelete: SetNull)
  course          Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  chiefComplaints ChiefComplaint[]
  notes           Note[]
  assignments     CaseAssignment[]
  caseLabs        CaseLab[]

  @@index([facultyCreatorId])
  @@index([courseId])
}

/// Faculty-uploaded lab or diagnostic asset for a case.
model CaseLab {
  id                 String   @id @default(cuid())
  patientId          Int
  title              String
  category           String?
  description        String?
  originalFilename   String
  fileUrl            String
  mimeType           String
  isVisibleToStudent Boolean  @default(false)
  uploadedByFacultyId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patient           Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedByFaculty User?   @relation("CaseLabsUploadedByFaculty", fields: [uploadedByFacultyId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([uploadedByFacultyId])
  @@index([patientId, isVisibleToStudent])
}

/// One-to-many from Patient: specific chief complaints.
model ChiefComplaint {
  id            Int    @id @default(autoincrement())
  patientId     Int
  complaintText String

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

/// Student clinical note per patient — covers all 13 form sections.
model Note {
  id              String    @id @default(uuid())
  patientId       Int
  studentId       String

  // Core clinical sections
  hpi             String    @default("")
  physicalExam    String    @default("")
  assessment      String?
  treatmentPlan   String?

  // Extended sections (all optional so existing rows remain valid)
  medications     String?
  allergies       String?
  familyHistory   String?
  socialHistory   String?
  procedures      String?
  diagnosis       String?
  labAndDiagnostics String?
  codingAndBilling  String?
  learningIssues    String?

  // Submission & grading
  isSubmitted     Boolean   @default(false)
  submittedAt     DateTime?
  grade           Float?

  // Faculty feedback
  feedback        String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, patientId], name: "studentId_patientId")
}

/// Links a student to a case (patient) — created by faculty.
model CaseAssignment {
  id                  String   @id @default(uuid())
  patientId           Int
  studentId           String
  assignedByFacultyId String
  createdAt           DateTime @default(now())

  patient           Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  student           User    @relation("CaseAssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignedByFaculty User    @relation("CaseAssignmentFaculty", fields: [assignedByFacultyId], references: [id], onDelete: Cascade)

  @@unique([patientId, studentId])
  @@index([patientId])
  @@index([studentId])
  @@index([assignedByFacultyId])
}

model AuditLog {
  id           String   @id @default(cuid())
  eventType    String
  message      String
  actorUserId  String?
  targetUserId String?
  metadata     Json?
  createdAt    DateTime @default(now())

  actorUser  User? @relation("AuditActor",  fields: [actorUserId],  references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([createdAt])
}
